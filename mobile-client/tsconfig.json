{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "lib": ["ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/hooks": ["lib/hooks/index.ts"],
      "@/*": ["*"],
      "@/app/*": ["app/*"],
      "@/screens/*": ["screens/*"],
      "@/components/*": ["components/*"],
      "@/context/*": ["context/*"],
      "@/lib/*": ["lib/*"],
      "@/navigation/*": ["navigation/*"],
      "@/store/*": ["store/*"],
      "@/types/*": ["types/*"]
    }
  },
  "include": [
    "App.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "context/**/*.ts",
    "context/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "navigation/**/*.ts",
    "navigation/**/*.tsx",
    "screens/**/*.ts",
    "screens/**/*.tsx",
    "store/**/*.ts",
    "store/**/*.tsx",
    "types/**/*.ts",
    "types/**/*.tsx",
    "*.ts",
    "*.tsx"
  ]
}
